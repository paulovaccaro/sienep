# Copiar este archivo a .env y completar los valores reales.
# El archivo .env va en la raíz del proyecto (al lado de pom.xml) y NUNCA se commitea.

# Contraseña de la base de datos PostgreSQL (Supabase)
DB_PASSWORD=your_database_password_here

# Clave secreta para firmar tokens JWT (mínimo 256 bits / 32 caracteres)
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_256_bits_long
